# SentinelAI — Environment Variables
# Copy to .env and fill in your values

# Required for Claude triage plugin
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for Gemini triage plugin (install with: pip install sentinelai[gemini])
# GEMINI_API_KEY=your-gemini-key-here

# Required for Jira ticket plugin
# JIRA_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECT_KEY=OPS

# Required for GitHub Issues ticket plugin
# GITHUB_TOKEN=ghp_your-token
# GITHUB_REPO=owner/repo

# Required for webhook alert source
# SENTINELAI_WEBHOOK_SECRET=your-shared-secret
# SENTINELAI_WEBHOOK_PORT=8090
